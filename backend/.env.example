# Copy this file to .env and adjust as needed.

# --- Database ---
# driver: sqlite (zero-config, default) or mysql
DB_DRIVER=sqlite
DB_PATH=storage/database.sqlite

# Only used when DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=workflow_engine
DB_USERNAME=root
DB_PASSWORD=

# --- Auth ---
# Change this to a long random string in any real deployment.
JWT_SECRET=please-change-this-to-a-random-secret-string
JWT_TTL_SECONDS=3600
